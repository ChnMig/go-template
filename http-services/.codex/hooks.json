{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/session-start.py",
            "timeout": 15,
            "statusMessage": "Loading Trellis context..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/inject-workflow-state.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
